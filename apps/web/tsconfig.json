{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "useDefineForClassFields": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": "./",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@crestly/shared": ["../../packages/shared/src/index.ts"],
      "@crestly/shared/*": ["../../packages/shared/src/*"],
      "@crestly/icons": ["../../packages/icons/src/index.tsx"],
      "@crestly/design": ["../../packages/design/src/index.ts"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
