# JWT signing secret. Generate with: openssl rand -base64 48
JWT_SECRET="change-me-to-a-long-random-string-min-48-chars"
JWT_EXPIRES_IN="12h"

# HTTP
PORT=4000
CORS_ORIGIN="http://localhost:5173"
NODE_ENV="development"
