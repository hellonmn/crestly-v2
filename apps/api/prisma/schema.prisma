generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model PartnerSchool {
  id                Int                 @id @default(autoincrement()) @db.UnsignedInt
  name              String              @db.VarChar(160)
  slug              String              @unique(map: "uniq_slug") @db.VarChar(64)
  status            PartnerSchoolStatus @default(onboarding)
  dbHost            String              @default("localhost") @map("db_host") @db.VarChar(120)
  dbName            String              @map("db_name") @db.VarChar(120)
  dbUser            String              @map("db_user") @db.VarChar(120)
  dbPassEnc         String?             @map("db_pass_enc") @db.Text
  contactPerson     String?             @map("contact_person") @db.VarChar(120)
  contactPhone      String?             @map("contact_phone") @db.VarChar(20)
  contactEmail      String?             @map("contact_email") @db.VarChar(160)
  city              String?             @db.VarChar(80)
  state             String?             @db.VarChar(80)
  address           String?             @db.VarChar(255)
  board             String?             @db.VarChar(60)
  latitude          Decimal?            @db.Decimal(10, 7)
  longitude         Decimal?            @db.Decimal(10, 7)
  maps_link         String?             @db.VarChar(255)
  geofence_school_m Int?                @default(100) @db.UnsignedSmallInt
  geofence_driver_m Int?                @default(50) @db.UnsignedSmallInt
  brandColor        String?             @map("brand_color") @db.VarChar(16)
  logoPath          String?             @map("logo_path") @db.VarChar(255)
  plan              String?             @db.VarChar(40)
  notes             String?             @db.Text
  onboardedAt       DateTime?           @map("onboarded_at") @db.Timestamp(0)
  createdAt         DateTime?           @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt         DateTime?           @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@index([status], map: "idx_status")
  @@map("partner_schools")
}

model PlatformAdmin {
  id           Int           @id @default(autoincrement()) @db.UnsignedInt
  name         String        @db.VarChar(120)
  email        String        @unique(map: "uniq_email") @db.VarChar(160)
  phone        String?       @db.VarChar(20)
  passwordHash String        @map("password_hash") @db.VarChar(255)
  status       AccountStatus @default(active)
  lastLoginAt  DateTime?     @map("last_login_at") @db.Timestamp(0)
  createdAt    DateTime?     @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt    DateTime?     @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)

  @@map("platform_admins")
}

model Session {
  code                String         @id @db.VarChar(10)
  label               String         @db.VarChar(40)
  isCurrent           Boolean        @default(false) @map("is_current")
  startedAt           DateTime       @map("started_at") @db.Date
  endedAt             DateTime       @map("ended_at") @db.Date
  promotedFrom        String?        @map("promoted_from") @db.VarChar(10)
  promotedAt          DateTime?      @map("promoted_at") @db.Timestamp(0)
  attendance          attendance[]
  fee_payments        fee_payments[]
  promotedFromSession Session?       @relation("SessionPromotion", fields: [promotedFrom], references: [code], onUpdate: Restrict, map: "fk_sessions_prev")
  promotedSessions    Session[]      @relation("SessionPromotion")
  studentFees         StudentFee[]

  @@index([promotedFrom], map: "fk_sessions_prev")
  @@index([isCurrent], map: "idx_current")
  @@map("sessions")
}

model SchoolInfo {
  k String  @id @db.VarChar(64)
  v String? @db.Text

  @@map("school_info")
}

model SiblingFamily {
  familyId     Int       @id @map("family_id") @db.UnsignedInt
  fatherName   String?   @map("father_name") @db.VarChar(120)
  motherName   String?   @map("mother_name") @db.VarChar(120)
  siblingCount Int?      @map("sibling_count") @db.UnsignedTinyInt
  membersText  String?   @map("members_text") @db.Text
  students     Student[]

  @@map("sibling_families")
}

model PickupPoint {
  id               Int                @id @default(autoincrement()) @db.UnsignedInt
  name             String             @unique(map: "uniq_pickup_name") @db.VarChar(160)
  latitude         Decimal?           @db.Decimal(10, 7)
  longitude        Decimal?           @db.Decimal(10, 7)
  distanceKm       Decimal?           @map("distance_km") @db.Decimal(5, 2)
  googleMapsLink   String?            @map("google_maps_link") @db.Text
  staff_attendance staff_attendance[]
  students         Student[]
  users            User[]

  @@map("pickup_points")
}

model Student {
  srNumber                 Int                     @id @map("sr_number") @db.UnsignedInt
  studentName              String                  @map("student_name") @db.VarChar(120)
  fatherName               String?                 @map("father_name") @db.VarChar(120)
  motherName               String?                 @map("mother_name") @db.VarChar(120)
  dob                      DateTime?               @db.Date
  age                      Int?                    @db.UnsignedTinyInt
  blood_group              String?                 @db.VarChar(8)
  gender                   StudentGender?
  address                  String?                 @db.Text
  home_city                String?                 @db.VarChar(80)
  home_state               String?                 @db.VarChar(80)
  home_address             String?                 @db.Text
  local_guardian_name      String?                 @db.VarChar(120)
  guardian_relation        String?                 @db.VarChar(60)
  local_guardian_contact   String?                 @db.VarChar(20)
  local_guardian_whatsapp  String?                 @db.VarChar(20)
  local_guardian_address   String?                 @db.Text
  class                    String                  @db.VarChar(16)
  section                  String                  @db.VarChar(8)
  stream                   String?                 @db.VarChar(16)
  sub_stream               String?                 @db.VarChar(16)
  schoolName               String?                 @map("school_name") @db.VarChar(120)
  board                    String?                 @db.VarChar(32)
  fatherContact            String?                 @map("father_contact") @db.VarChar(20)
  father_whatsapp          String?                 @db.VarChar(20)
  motherContact            String?                 @map("mother_contact") @db.VarChar(20)
  mother_whatsapp          String?                 @db.VarChar(20)
  callingNumber            String?                 @map("calling_number") @db.VarChar(20)
  whatsappNumber           String?                 @map("whatsapp_number") @db.VarChar(20)
  pickupPointId            Int?                    @map("pickup_point_id") @db.UnsignedInt
  is_hostel                Boolean                 @default(false)
  familyId                 Int?                    @map("family_id") @db.UnsignedInt
  status                   StudentStatus           @default(active)
  createdAt                DateTime?               @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                DateTime?               @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  academic_contact_person  String?                 @db.VarChar(120)
  academic_calling_number  String?                 @db.VarChar(20)
  academic_whatsapp_number String?                 @db.VarChar(20)
  fee_contact_person       String?                 @db.VarChar(120)
  fee_calling_number       String?                 @db.VarChar(20)
  fee_whatsapp_number      String?                 @db.VarChar(20)
  pickup_point_name        String?                 @db.VarChar(120)
  pickup_latitude          Decimal?                @db.Decimal(10, 7)
  pickup_longitude         Decimal?                @db.Decimal(10, 7)
  pickup_distance_km       Decimal?                @db.Decimal(6, 2)
  pickup_maps_link         String?                 @db.VarChar(255)
  attendance               attendance[]
  exam_co_grades           exam_co_grades[]
  exam_marks               exam_marks[]
  fee_payments             fee_payments[]
  hostel_allocations       hostel_allocations[]
  student_edit_requests    student_edit_requests[]
  fees                     StudentFee[]
  family                   SiblingFamily?          @relation(fields: [familyId], references: [familyId], onUpdate: Restrict, map: "fk_students_family")
  pickupPoint              PickupPoint?            @relation(fields: [pickupPointId], references: [id], onUpdate: Restrict, map: "fk_students_pickup")

  @@index([class, section], map: "idx_class_section")
  @@index([familyId], map: "idx_family")
  @@index([pickupPointId], map: "idx_pickup")
  @@index([studentName], map: "idx_name")
  @@map("students")
}

model StudentFee {
  srNumber             Int                     @map("sr_number") @db.UnsignedInt
  sessionCode          String                  @map("session_code") @db.VarChar(10)
  admissionStatus      FeeAdmissionStatus      @default(Continuing) @map("admission_status")
  siblingPosition      String?                 @map("sibling_position") @db.VarChar(32)
  siblingDiscountPct   Decimal                 @default(0.00) @map("sibling_discount_pct") @db.Decimal(5, 2)
  lodging_discount_pct Decimal                 @default(0.00) @db.Decimal(5, 2)
  tuitionOriginal      Int                     @default(0) @map("tuition_original") @db.UnsignedInt
  tuitionDiscount      Int                     @default(0) @map("tuition_discount") @db.UnsignedInt
  tuitionPayable       Int                     @default(0) @map("tuition_payable") @db.UnsignedInt
  annualCharges        Int                     @default(0) @map("annual_charges") @db.UnsignedInt
  activityFee          Int                     @default(0) @map("activity_fee") @db.UnsignedInt
  examFee              Int                     @default(0) @map("exam_fee") @db.UnsignedInt
  books_uniform_est    Int                     @default(0) @db.UnsignedInt
  distanceKm           Decimal?                @map("distance_km") @db.Decimal(5, 2)
  transportSlab        String?                 @map("transport_slab") @db.VarChar(16)
  transportFee         Int                     @default(0) @map("transport_fee") @db.UnsignedInt
  is_hostel            Boolean                 @default(false)
  room_type            student_fees_room_type?
  hostel_lodging       Int                     @default(0) @db.UnsignedInt
  hostel_mess          Int                     @default(0) @db.UnsignedInt
  hostel_common        Int                     @default(0) @db.UnsignedInt
  hostel_one_time      Int                     @default(0) @db.UnsignedInt
  yearlyRecurringTotal Int                     @default(0) @map("yearly_recurring_total") @db.UnsignedInt
  registrationFee      Int                     @default(0) @map("registration_fee") @db.UnsignedInt
  admissionFee         Int                     @default(0) @map("admission_fee") @db.UnsignedInt
  cautionMoney         Int                     @default(0) @map("caution_money") @db.UnsignedInt
  firstYearExtras      Int                     @default(0) @map("first_year_extras") @db.UnsignedInt
  totalThisYear        Int                     @default(0) @map("total_this_year") @db.UnsignedInt
  quarterlyInstallment Int                     @default(0) @map("quarterly_installment") @db.UnsignedInt
  monthlyEmi           Int                     @default(0) @map("monthly_emi") @db.UnsignedInt
  paidAmount           Int                     @default(0) @map("paid_amount") @db.UnsignedInt
  dueAmount            Int                     @default(0) @map("due_amount") @db.UnsignedInt
  paymentStatus        FeePaymentStatus        @default(pending) @map("payment_status")
  classAtSession       String?                 @map("class_at_session") @db.VarChar(16)
  sectionAtSession     String?                 @map("section_at_session") @db.VarChar(8)
  session              Session                 @relation(fields: [sessionCode], references: [code], onUpdate: Restrict, map: "fk_fees_session")
  student              Student                 @relation(fields: [srNumber], references: [srNumber], onDelete: Cascade, onUpdate: Restrict, map: "fk_fees_student")

  @@id([srNumber, sessionCode])
  @@index([sessionCode], map: "idx_session")
  @@index([paymentStatus], map: "idx_status")
  @@index([admissionStatus], map: "idx_admission")
  @@map("student_fees")
}

model User {
  id                                                                Int                       @id @default(autoincrement()) @db.UnsignedInt
  employee_id                                                       String?                   @db.VarChar(20)
  name                                                              String                    @db.VarChar(120)
  designation                                                       String?                   @db.VarChar(120)
  department                                                        String?                   @db.VarChar(80)
  gender                                                            users_gender?
  dob                                                               DateTime?                 @db.Date
  date_of_joining                                                   DateTime?                 @db.Date
  experience_years                                                  Int?                      @db.UnsignedTinyInt
  qualification                                                     String?                   @db.VarChar(160)
  employment_type                                                   String?                   @db.VarChar(40)
  reports_to                                                        String?                   @db.VarChar(120)
  whatsapp                                                          String?                   @db.VarChar(20)
  emergency_contact                                                 String?                   @db.VarChar(20)
  address                                                           String?                   @db.Text
  blood_group                                                       String?                   @db.VarChar(8)
  monthly_salary                                                    Int?                      @db.UnsignedInt
  class_teacher_of                                                  String?                   @db.VarChar(60)
  email                                                             String?                   @unique(map: "uniq_email") @db.VarChar(120)
  phone                                                             String?                   @unique(map: "uniq_phone") @db.VarChar(20)
  passwordHash                                                      String?                   @map("password_hash") @db.VarChar(255)
  roleId                                                            Int?                      @map("role_id") @db.UnsignedInt
  reporting_user_id                                                 Int?                      @db.UnsignedInt
  geofence_pickup_id                                                Int?                      @db.UnsignedInt
  status                                                            AccountStatus             @default(active)
  lastLoginAt                                                       DateTime?                 @map("last_login_at") @db.Timestamp(0)
  createdAt                                                         DateTime?                 @default(now()) @map("created_at") @db.Timestamp(0)
  updatedAt                                                         DateTime?                 @default(now()) @updatedAt @map("updated_at") @db.Timestamp(0)
  admission_enquiries_admission_enquiries_assigned_toTousers        admission_enquiries[]     @relation("admission_enquiries_assigned_toTousers")
  admission_enquiries_admission_enquiries_created_byTousers         admission_enquiries[]     @relation("admission_enquiries_created_byTousers")
  admission_followups                                               admission_followups[]
  class_diary_class_diary_created_byTousers                         class_diary[]             @relation("class_diary_created_byTousers")
  class_diary_class_diary_teacher_user_idTousers                    class_diary[]             @relation("class_diary_teacher_user_idTousers")
  dashboard_reviews                                                 dashboard_reviews[]
  exam_co_grades                                                    exam_co_grades[]
  exam_marks                                                        exam_marks[]
  holidays                                                          holidays[]
  leave_balance_overrides_leave_balance_overrides_created_byTousers leave_balance_overrides[] @relation("leave_balance_overrides_created_byTousers")
  leave_balance_overrides_leave_balance_overrides_user_idTousers    leave_balance_overrides[] @relation("leave_balance_overrides_user_idTousers")
  leaves_leaves_decided_byTousers                                   leaves[]                  @relation("leaves_decided_byTousers")
  leaves_leaves_user_idTousers                                      leaves[]                  @relation("leaves_user_idTousers")
  notifications                                                     notifications[]
  sections                                                          sections[]
  staff_attendance                                                  staff_attendance[]
  staff_schedules_staff_schedules_created_byTousers                 staff_schedules[]         @relation("staff_schedules_created_byTousers")
  staff_schedules_staff_schedules_user_idTousers                    staff_schedules[]         @relation("staff_schedules_user_idTousers")
  student_edit_requests_student_edit_requests_reviewed_byTousers    student_edit_requests[]   @relation("student_edit_requests_reviewed_byTousers")
  student_edit_requests_student_edit_requests_requested_byTousers   student_edit_requests[]   @relation("student_edit_requests_requested_byTousers")
  student_promotions                                                student_promotions[]
  timetable_entries_timetable_entries_created_byTousers             timetable_entries[]       @relation("timetable_entries_created_byTousers")
  timetable_entries_timetable_entries_teacher_user_idTousers        timetable_entries[]       @relation("timetable_entries_teacher_user_idTousers")
  timetable_entries_timetable_entries_teacher_user_id2Tousers       timetable_entries[]       @relation("timetable_entries_teacher_user_id2Tousers")
  pickup_points                                                     PickupPoint?              @relation(fields: [geofence_pickup_id], references: [id], onUpdate: Restrict, map: "fk_user_geofence")
  users                                                             User?                     @relation("usersTousers", fields: [reporting_user_id], references: [id], onUpdate: Restrict, map: "fk_user_reports_to")
  other_users                                                       User[]                    @relation("usersTousers")
  role                                                              Role?                     @relation(fields: [roleId], references: [id], onUpdate: Restrict, map: "fk_user_role")
  voucher_approvers                                                 voucher_approvers[]
  voucher_attachments                                               voucher_attachments[]
  vouchers_vouchers_created_byTousers                               vouchers[]                @relation("vouchers_created_byTousers")
  vouchers_vouchers_paid_byTousers                                  vouchers[]                @relation("vouchers_paid_byTousers")
  vouchers_vouchers_rejected_byTousers                              vouchers[]                @relation("vouchers_rejected_byTousers")
  vouchers_vouchers_salary_user_idTousers                           vouchers[]                @relation("vouchers_salary_user_idTousers")

  @@index([roleId], map: "idx_role")
  @@index([status], map: "idx_status")
  @@index([geofence_pickup_id], map: "idx_geofence")
  @@index([reporting_user_id], map: "idx_reports_to")
  @@map("users")
}

model Role {
  id              Int              @id @default(autoincrement()) @db.UnsignedInt
  slug            String           @unique(map: "uniq_role_slug") @db.VarChar(40)
  name            String           @db.VarChar(80)
  description     String?          @db.VarChar(255)
  isSystem        Boolean          @default(false) @map("is_system")
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(0)
  rolePermissions RolePermission[]
  users           User[]

  @@map("roles")
}

model Permission {
  id              Int              @id @default(autoincrement()) @db.UnsignedInt
  permKey         String           @unique(map: "uniq_perm_key") @map("perm_key") @db.VarChar(60)
  label           String           @db.VarChar(120)
  module          String           @db.VarChar(40)
  sortOrder       Int              @default(0) @map("sort_order") @db.UnsignedInt
  rolePermissions RolePermission[]

  @@index([module], map: "idx_module")
  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id") @db.UnsignedInt
  permissionId Int        @map("permission_id") @db.UnsignedInt
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_rp_perm")
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_rp_role")

  @@id([roleId, permissionId])
  @@index([permissionId], map: "fk_rp_perm")
  @@map("role_permissions")
}

model admission_enquiries {
  id                                           Int                        @id @default(autoincrement()) @db.UnsignedInt
  child_name                                   String                     @db.VarChar(120)
  parent_name                                  String?                    @db.VarChar(120)
  phone                                        String                     @db.VarChar(20)
  email                                        String?                    @db.VarChar(160)
  class_seeking                                String?                    @db.VarChar(16)
  source                                       admission_enquiries_source @default(walk_in)
  source_detail                                String?                    @db.VarChar(160)
  status                                       admission_enquiries_status @default(new)
  follow_up_date                               DateTime?                  @db.Date
  assigned_to                                  Int?                       @db.UnsignedInt
  city                                         String?                    @db.VarChar(80)
  notes                                        String?                    @db.Text
  lost_reason                                  String?                    @db.VarChar(160)
  converted_sr_number                          Int?                       @db.UnsignedInt
  created_by                                   Int?                       @db.UnsignedInt
  created_at                                   DateTime?                  @default(now()) @db.Timestamp(0)
  updated_at                                   DateTime?                  @default(now()) @db.Timestamp(0)
  users_admission_enquiries_assigned_toTousers User?                      @relation("admission_enquiries_assigned_toTousers", fields: [assigned_to], references: [id], onUpdate: Restrict, map: "fk_enq_assignee")
  users_admission_enquiries_created_byTousers  User?                      @relation("admission_enquiries_created_byTousers", fields: [created_by], references: [id], onUpdate: Restrict, map: "fk_enq_creator")
  admission_followups                          admission_followups[]

  @@index([created_by], map: "fk_enq_creator")
  @@index([assigned_to], map: "idx_assigned")
  @@index([follow_up_date], map: "idx_followup")
  @@index([status], map: "idx_status")
}

model admission_followups {
  id                  Int                 @id @default(autoincrement()) @db.UnsignedInt
  enquiry_id          Int                 @db.UnsignedInt
  note                String?             @db.Text
  status_to           String?             @db.VarChar(20)
  next_follow_up      DateTime?           @db.Date
  created_by          Int?                @db.UnsignedInt
  created_at          DateTime?           @default(now()) @db.Timestamp(0)
  users               User?               @relation(fields: [created_by], references: [id], onUpdate: Restrict, map: "fk_fu_creator")
  admission_enquiries admission_enquiries @relation(fields: [enquiry_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "fk_fu_enq")

  @@index([created_by], map: "fk_fu_creator")
  @@index([enquiry_id], map: "idx_enq")
}

model app_settings {
  setting_key   String    @id @db.VarChar(80)
  setting_value String?   @db.Text
  updated_by    Int?      @db.UnsignedInt
  updated_at    DateTime? @default(now()) @db.Timestamp(0)
}

model attendance {
  id              Int               @id @default(autoincrement()) @db.UnsignedInt
  sr_number       Int               @db.UnsignedInt
  session_code    String            @db.VarChar(10)
  attendance_date DateTime          @db.Date
  status          attendance_status @default(present)
  remarks         String?           @db.VarChar(255)
  marked_by       String?           @db.VarChar(64)
  marked_at       DateTime?         @default(now()) @db.Timestamp(0)
  created_at      DateTime?         @default(now()) @db.Timestamp(0)
  sessions        Session           @relation(fields: [session_code], references: [code], onUpdate: Restrict, map: "fk_attn_session")
  students        Student           @relation(fields: [sr_number], references: [srNumber], onDelete: Cascade, onUpdate: Restrict, map: "fk_attn_student")

  @@unique([sr_number, attendance_date], map: "uniq_sr_date")
  @@index([attendance_date], map: "idx_date")
  @@index([session_code, attendance_date], map: "idx_session_date")
  @@index([status], map: "idx_status")
}

model brand_images {
  id               Int      @id @default(autoincrement()) @db.UnsignedInt
  prompt_set_id    Int?     @db.UnsignedInt
  slide_no         Int      @default(1) @db.UnsignedInt
  prompt           String   @db.MediumText
  provider         String   @default("ideogram") @db.VarChar(20)
  model            String?  @db.VarChar(40)
  aspect_ratio     String?  @db.VarChar(20)
  resolution       String?  @db.VarChar(20)
  seed             BigInt?
  image_path       String?  @db.VarChar(255)
  image_url_remote String?  @db.VarChar(512)
  is_safe          Boolean  @default(true)
  status           String   @default("done") @db.VarChar(10)
  error            String?  @db.VarChar(255)
  created_by       Int?     @db.UnsignedInt
  created_at       DateTime @default(now()) @db.Timestamp(0)

  @@index([created_at], map: "idx_created")
  @@index([prompt_set_id, slide_no], map: "idx_set")
}

model brand_prompt_sets {
  id            Int      @id @default(autoincrement()) @db.UnsignedInt
  feature_key   String   @db.VarChar(40)
  feature_label String   @db.VarChar(120)
  format        String   @db.VarChar(20)
  tone          String   @db.VarChar(20)
  audience      String   @db.VarChar(20)
  color_theme   String?  @db.Text
  headline      String?  @db.VarChar(180)
  slides_json   String   @db.MediumText
  extras        String?  @db.Text
  created_by    Int?     @db.UnsignedInt
  created_at    DateTime @default(now()) @db.Timestamp(0)

  @@index([created_at], map: "idx_created")
  @@index([feature_key], map: "idx_feature")
}

model class_diary {
  id                                       Int                @id @default(autoincrement()) @db.UnsignedInt
  session_code                             String             @db.VarChar(10)
  class_slug                               String             @db.VarChar(16)
  section_code                             String             @db.VarChar(8)
  diary_date                               DateTime           @db.Date
  period_id                                Int?               @db.UnsignedInt
  subject_id                               Int?               @db.UnsignedInt
